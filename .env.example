# Turso (libSQL) – create a DB at https://turso.tech
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token

# JWT for auth (use a long random string in production)
JWT_SECRET=your-jwt-secret

# Stripe — key and price IDs must match mode (test vs live)
# Test: sk_test_... and create Prices in Dashboard with "Test mode" on → use those price_ ids
# Live: sk_live_... and use your live price ids (e.g. Pro/Team)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_TEAM=price_...
